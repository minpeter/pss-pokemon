POKEMON_ROM_PATH=/absolute/path/to/pokemon-red-or-blue.gb
# Optional. Without it a cold boot starts at the title screen (the backend warms
# up past the black boot frame). For a deterministic in-game start, generate one
# with: cd backend && uv run python -m pokemon_harness.make_intro_save_state
# POKEMON_SAVE_STATE_PATH=/absolute/path/to/intro-done.state
# Optional: set POKEMON_BACKEND_URL only when you want to use an already-running external backend.
# POKEMON_BACKEND_URL=http://127.0.0.1:8765
# Managed CLI backends default to real mode. Use fake only for ROM-less local QA.
# POKEMON_BACKEND_MODE=fake
# POKEMON_BACKEND_SESSION_ROOT=.local/backend-sessions
POKEMON_AI_BASE_URL=https://codex.nekos.me/v1
POKEMON_AI_API_KEY=
POKEMON_AI_MODEL=gpt-5.5
POKEMON_AGENT_SESSION_ID=pokemon-agent
# Optional trace recording. Keep shared exports free of ROM paths, API keys,
# save states, and inline real-ROM screenshot bodies.
# POKEMON_TRACE_ROOT=.local/runs
# POKEMON_TRACE_RUN_ID=manual-smoke
